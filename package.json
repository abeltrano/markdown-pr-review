{
  "name": "ado-markdown-pr-reviewer",
  "displayName": "ADO Markdown PR Reviewer",
  "description": "Review Azure DevOps PR markdown files in a rendered view and post comments anchored to raw line ranges.",
  "version": "0.1.0",
  "publisher": "anbeltra",
  "private": true,
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=20"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:adoMdReview.openPullRequest",
    "onView:adoMdReview.fileTree",
    "onView:adoMdReview.commentInput",
    "onCustomEditor:adoMdReview.renderedView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "adoMdReview.openPullRequest",
        "title": "ADO MD Review: Open Pull Request…",
        "category": "ADO MD Review"
      },
      {
        "command": "adoMdReview.refreshThreads",
        "title": "ADO MD Review: Refresh Threads",
        "category": "ADO MD Review",
        "icon": "$(refresh)"
      },
      {
        "command": "adoMdReview.addComment",
        "title": "ADO MD Review: Add Comment to Selection",
        "category": "ADO MD Review"
      },
      {
        "command": "adoMdReview.refreshToHead",
        "title": "ADO MD Review: Refresh to Head Commit",
        "category": "ADO MD Review"
      },
      {
        "command": "adoMdReview.closeSession",
        "title": "ADO MD Review: Close Session",
        "category": "ADO MD Review"
      }
    ],
    "keybindings": [
      {
        "command": "adoMdReview.addComment",
        "key": "ctrl+alt+c",
        "mac": "cmd+alt+c",
        "when": "activeCustomEditorId == 'adoMdReview.renderedView'"
      },
      {
        "command": "adoMdReview.refreshThreads",
        "key": "ctrl+alt+r",
        "mac": "cmd+alt+r",
        "when": "activeCustomEditorId == 'adoMdReview.renderedView'"
      },
      {
        "command": "adoMdReview.refreshToHead",
        "key": "f5",
        "when": "activeCustomEditorId == 'adoMdReview.renderedView'"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "adoMdReview",
          "title": "ADO MD Review",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "views": {
      "adoMdReview": [
        {
          "id": "adoMdReview.fileTree",
          "name": "Changed Files",
          "icon": "$(files)"
        },
        {
          "id": "adoMdReview.commentInput",
          "name": "Comment Input",
          "type": "webview",
          "icon": "$(comment)"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "adoMdReview.refreshThreads",
          "when": "view == adoMdReview.fileTree",
          "group": "navigation"
        },
        {
          "command": "adoMdReview.openPullRequest",
          "when": "view == adoMdReview.fileTree",
          "group": "navigation"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "adoMdReview.renderedView",
        "displayName": "ADO MD Rendered View",
        "selector": [
          {
            "filenamePattern": "*.md"
          },
          {
            "filenamePattern": "*.markdown"
          },
          {
            "filenamePattern": "*.mdx"
          }
        ],
        "priority": "option"
      }
    ],
    "configuration": {
      "title": "ADO Markdown PR Reviewer",
      "properties": {
        "adoMdReview.defaultOrganization": {
          "type": "string",
          "default": "",
          "description": "Default Azure DevOps organization (used for bare-PR-id input)."
        },
        "adoMdReview.defaultProject": {
          "type": "string",
          "default": "",
          "description": "Default Azure DevOps project (used for bare-PR-id input)."
        },
        "adoMdReview.staleCommitPollSeconds": {
          "type": "number",
          "default": 30,
          "minimum": 15,
          "maximum": 60,
          "description": "How often to check for a newer head commit on the active PR (seconds)."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc --noEmit && node esbuild.js",
    "watch": "node esbuild.js --watch",
    "build": "tsc --noEmit && node esbuild.js --production",
    "package": "npm run build && vsce package --no-yarn",
    "test": "mocha",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/chai": "^4.3.20",
    "@types/diff": "^7.0.2",
    "@types/markdown-it": "^14.1.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.32.0",
    "chai": "^4.5.0",
    "esbuild": "^0.23.0",
    "mocha": "^11.7.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "diff": "^5.2.0",
    "markdown-it": "^14.1.0",
    "mermaid": "^10.9.1"
  }
}
