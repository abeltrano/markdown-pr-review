{
  "name": "ado-markdown-pr-reviewer",
  "displayName": "ADO Markdown PR Reviewer",
  "description": "Review Azure DevOps PR markdown files in a rendered view and post comments anchored to raw line ranges.",
  "version": "0.4.8",
  "publisher": "anbeltra",
  "private": true,
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=20"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:adoMdReview.openPullRequest",
    "onView:adoMdReview.fileTree",
    "onView:adoMdReview.commentInput",
    "onCustomEditor:adoMdReview.renderedView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "adoMdReview.openPullRequest",
        "title": "Open Pull Request…",
        "category": "ADO MD Review"
      },
      {
        "command": "adoMdReview.refreshThreads",
        "title": "Refresh Threads",
        "category": "ADO MD Review",
        "icon": "$(refresh)"
      },
      {
        "command": "adoMdReview.addComment",
        "title": "Add Comment to Selection",
        "category": "ADO MD Review"
      },
      {
        "command": "adoMdReview.refreshToHead",
        "title": "Refresh to Head Commit",
        "category": "ADO MD Review"
      },
      {
        "command": "adoMdReview.closeSession",
        "title": "Close Session",
        "category": "ADO MD Review"
      }
    ],
    "keybindings": [
      {
        "command": "adoMdReview.addComment",
        "key": "ctrl+alt+c",
        "mac": "cmd+alt+c",
        "when": "activeCustomEditorId == 'adoMdReview.renderedView'"
      },
      {
        "command": "adoMdReview.refreshThreads",
        "key": "ctrl+alt+r",
        "mac": "cmd+alt+r",
        "when": "activeCustomEditorId == 'adoMdReview.renderedView'"
      },
      {
        "command": "adoMdReview.refreshToHead",
        "key": "f5",
        "when": "activeCustomEditorId == 'adoMdReview.renderedView'"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "adoMdReview",
          "title": "ADO MD Review",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "views": {
      "adoMdReview": [
        {
          "id": "adoMdReview.fileTree",
          "name": "Changed Files",
          "icon": "$(files)"
        },
        {
          "id": "adoMdReview.commentInput",
          "name": "Comment Input",
          "type": "webview",
          "icon": "$(comment)"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "adoMdReview.refreshThreads",
          "when": "view == adoMdReview.fileTree",
          "group": "navigation"
        },
        {
          "command": "adoMdReview.openPullRequest",
          "when": "view == adoMdReview.fileTree",
          "group": "navigation"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "adoMdReview.renderedView",
        "displayName": "ADO MD Rendered View",
        "selector": [
          {
            "filenamePattern": "*.md"
          },
          {
            "filenamePattern": "*.markdown"
          },
          {
            "filenamePattern": "*.mdx"
          }
        ],
        "priority": "option"
      }
    ],
    "configuration": {
      "title": "ADO Markdown PR Reviewer",
      "properties": {
        "adoMdReview.defaultOrganization": {
          "type": "string",
          "default": "",
          "markdownDescription": "Default Azure DevOps organization. When set together with `#adoMdReview.defaultProject#`, the **Open Pull Request** command will accept a bare PR number (e.g., `12345`) in addition to full URLs.\n\nExample: `contoso` (from `https://dev.azure.com/contoso/...`)."
        },
        "adoMdReview.defaultProject": {
          "type": "string",
          "default": "",
          "markdownDescription": "Default Azure DevOps project. Must be set together with `#adoMdReview.defaultOrganization#` for bare-PR-id input to work.\n\nExample: `MyProject`."
        },
        "adoMdReview.staleCommitPollSeconds": {
          "type": "number",
          "default": 30,
          "minimum": 15,
          "maximum": 60,
          "markdownDescription": "How often (in seconds) to check whether a newer head commit has been pushed to the active PR. Range 15–60. When a newer commit is detected, a banner appears in the rendered view offering to refresh."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc --noEmit && node esbuild.js",
    "watch": "node esbuild.js --watch",
    "build": "tsc --noEmit && node esbuild.js --production",
    "package": "npm run build && vsce package --no-yarn",
    "test": "mocha",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/chai": "^4.3.20",
    "@types/diff": "^7.0.2",
    "@types/markdown-it": "^14.1.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.32.0",
    "chai": "^4.5.0",
    "esbuild": "^0.23.0",
    "mocha": "^11.7.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "diff": "^5.2.0",
    "markdown-it": "^14.1.0",
    "mermaid": "^10.9.1"
  }
}
