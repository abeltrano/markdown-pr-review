{
  "name": "md-pr-review",
  "displayName": "Azure DevOps Markdown PR Review",
  "description": "Review markdown pull-request files in a rendered view and post comments anchored to raw line ranges.",
  "version": "0.5.0",
  "publisher": "abeltrano",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abeltrano/markdown-pr-review.git"
  },
  "bugs": {
    "url": "https://github.com/abeltrano/markdown-pr-review/issues"
  },
  "homepage": "https://github.com/abeltrano/markdown-pr-review#readme",
  "icon": "media/marketplace.png",
  "galleryBanner": {
    "color": "#000000",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=20"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "markdown",
    "pull request",
    "code review",
    "design review",
    "design document",
    "azure devops",
    "ado",
    "comments"
  ],
  "activationEvents": [
    "onCommand:markdownPrReview.openPullRequest",
    "onView:markdownPrReview.fileTree",
    "onView:markdownPrReview.recentPullRequests",
    "onView:markdownPrReview.commentInput",
    "onCustomEditor:markdownPrReview.renderedView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "markdownPrReview.openPullRequest",
        "title": "Open Pull Request…",
        "shortTitle": "Open PR",
        "category": "Markdown PR Review"
      },
      {
        "command": "markdownPrReview.refreshThreads",
        "title": "Refresh Threads",
        "category": "Markdown PR Review",
        "icon": "$(refresh)"
      },
      {
        "command": "markdownPrReview.showMarkdownOnly",
        "title": "Show Markdown Files Only",
        "category": "Markdown PR Review",
        "icon": "$(filter)"
      },
      {
        "command": "markdownPrReview.showAllFiles",
        "title": "Show All Files",
        "category": "Markdown PR Review",
        "icon": "$(filter-filled)"
      },
      {
        "command": "markdownPrReview.addComment",
        "title": "Add Comment to Selection",
        "category": "Markdown PR Review"
      },
      {
        "command": "markdownPrReview.refreshToHead",
        "title": "Refresh to Head Commit",
        "category": "Markdown PR Review"
      },
      {
        "command": "markdownPrReview.closeSession",
        "title": "Close Session",
        "category": "Markdown PR Review"
      },
      {
        "command": "markdownPrReview.closePullRequest",
        "title": "Close Pull Request",
        "category": "Markdown PR Review",
        "icon": "$(close)"
      },
      {
        "command": "markdownPrReview.closeAllPullRequests",
        "title": "Close All Pull Requests",
        "category": "Markdown PR Review",
        "icon": "$(close-all)"
      }
    ],
    "keybindings": [
      {
        "command": "markdownPrReview.addComment",
        "key": "ctrl+alt+c",
        "mac": "cmd+alt+c",
        "when": "activeCustomEditorId == 'markdownPrReview.renderedView'"
      },
      {
        "command": "markdownPrReview.refreshThreads",
        "key": "ctrl+alt+r",
        "mac": "cmd+alt+r",
        "when": "activeCustomEditorId == 'markdownPrReview.renderedView'"
      },
      {
        "command": "markdownPrReview.refreshToHead",
        "key": "f5",
        "when": "activeCustomEditorId == 'markdownPrReview.renderedView'"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "markdownPrReview",
          "title": "Markdown PR Review",
          "icon": "media/activity-bar.svg"
        }
      ]
    },
    "views": {
      "markdownPrReview": [
        {
          "id": "markdownPrReview.fileTree",
          "name": "Changed Files",
          "icon": "$(files)"
        },
        {
          "id": "markdownPrReview.recentPullRequests",
          "name": "Recent Pull Requests",
          "icon": "$(history)"
        },
        {
          "id": "markdownPrReview.commentInput",
          "name": "Comment Input",
          "type": "webview",
          "icon": "$(comment)"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "markdownPrReview.openPullRequest",
          "when": "view == markdownPrReview.fileTree",
          "group": "navigation@1"
        },
        {
          "command": "markdownPrReview.showMarkdownOnly",
          "when": "view == markdownPrReview.fileTree && !markdownPrReview.markdownOnly",
          "group": "navigation@2"
        },
        {
          "command": "markdownPrReview.showAllFiles",
          "when": "view == markdownPrReview.fileTree && markdownPrReview.markdownOnly",
          "group": "navigation@2"
        },
        {
          "command": "markdownPrReview.refreshThreads",
          "when": "view == markdownPrReview.fileTree",
          "group": "navigation@3"
        },
        {
          "command": "markdownPrReview.closeAllPullRequests",
          "when": "view == markdownPrReview.fileTree",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "markdownPrReview.closePullRequest",
          "when": "view == markdownPrReview.fileTree && viewItem == markdownPrReviewPullRequest",
          "group": "inline"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "markdownPrReview.renderedView",
        "displayName": "Markdown PR Review",
        "selector": [
          {
            "filenamePattern": "*.md"
          },
          {
            "filenamePattern": "*.markdown"
          },
          {
            "filenamePattern": "*.mdx"
          }
        ],
        "priority": "option"
      }
    ],
    "configuration": {
      "title": "Markdown PR Review",
      "properties": {
        "markdownPrReview.defaultOrganization": {
          "type": "string",
          "default": "",
          "markdownDescription": "Default Azure DevOps organization. When set together with `#markdownPrReview.defaultProject#`, the **Open Pull Request** command will accept a bare PR number (e.g., `12345`) in addition to full URLs.\n\nExample: `contoso` (from `https://dev.azure.com/contoso/...`)."
        },
        "markdownPrReview.defaultProject": {
          "type": "string",
          "default": "",
          "markdownDescription": "Default Azure DevOps project. Must be set together with `#markdownPrReview.defaultOrganization#` for bare-PR-id input to work.\n\nExample: `MyProject`."
        },
        "markdownPrReview.staleCommitPollSeconds": {
          "type": "number",
          "default": 30,
          "minimum": 15,
          "maximum": 60,
          "markdownDescription": "How often (in seconds) to check whether a newer head commit has been pushed to the active PR. Range 15–60. When a newer commit is detected, a banner appears in the rendered view offering to refresh."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc --noEmit && node esbuild.js",
    "watch": "node esbuild.js --watch",
    "build": "tsc --noEmit && node esbuild.js --production",
    "lint": "eslint .",
    "package": "npm run build && vsce package --no-yarn",
    "test": "mocha",
    "test:coverage": "c8 mocha",
    "release:notes": "git-cliff --output CHANGELOG.md"
  },
  "c8": {
    "all": true,
    "include": [
      "src/**/*.ts"
    ],
    "exclude": [
      "**/*.d.ts",
      "src/types.ts",
      "src/extension.ts",
      "src/session-manager.ts",
      "src/command-registry.ts",
      "src/auth-manager.ts",
      "src/comment-input-view-provider.ts",
      "src/error-utils.ts",
      "src/logger.ts",
      "src/mdpr-uri.ts",
      "src/stale-pr-watcher.ts",
      "src/status-bar.ts",
      "src/views/csp.ts",
      "src/views/custom-editor-provider.ts",
      "src/views/file-decoration-provider.ts",
      "src/views/mdpr-content-provider.ts",
      "src/views/file-tree-provider.ts",
      "src/views/recent-pr-tree-provider.ts",
      "src/views/rendered-view/**",
      "src/views/comment-input/**",
      "src/ado-client.ts",
      "src/comment-controller.ts"
    ],
    "reporter": [
      "text",
      "text-summary",
      "html",
      "lcov"
    ],
    "reports-dir": "coverage",
    "check-coverage": true,
    "lines": 93,
    "statements": 93,
    "functions": 95,
    "branches": 80,
    "excludeAfterRemap": true
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/chai": "^5.2.3",
    "@types/diff": "^8.0.0",
    "@types/markdown-it": "^14.1.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.1.0",
    "@types/vscode": "^1.125.0",
    "@vscode/codicons": "^0.0.45",
    "@vscode/vsce": "^3.9.2",
    "c8": "^11.0.0",
    "chai": "^6.2.2",
    "esbuild": "^0.28.0",
    "eslint": "^10.6.0",
    "git-cliff": "^2.13.1",
    "mocha": "^11.7.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0"
  },
  "dependencies": {
    "diff": "^9.0.0",
    "dompurify": "^3.4.8",
    "markdown-it": "^14.1.0",
    "mermaid": "^11.15.0"
  },
  "overrides": {
    "mocha": {
      "diff": "^8.0.3",
      "serialize-javascript": "^7.0.5"
    }
  }
}
