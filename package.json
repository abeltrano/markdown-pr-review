{
  "name": "markdown-pr-review",
  "displayName": "Markdown PR Review",
  "description": "Review Azure DevOps PR markdown files in a rendered view and post comments anchored to raw line ranges.",
  "version": "0.4.17",
  "publisher": "anbeltra",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abeltrano/markdown-pr-review.git"
  },
  "bugs": {
    "url": "https://github.com/abeltrano/markdown-pr-review/issues"
  },
  "homepage": "https://github.com/abeltrano/markdown-pr-review#readme",
  "icon": "media/marketplace.png",
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=20"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:markdownPrReview.openPullRequest",
    "onView:markdownPrReview.fileTree",
    "onView:markdownPrReview.commentInput",
    "onCustomEditor:markdownPrReview.renderedView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "markdownPrReview.openPullRequest",
        "title": "Open Pull Request…",
        "shortTitle": "Open PR",
        "category": "Markdown PR Review"
      },
      {
        "command": "markdownPrReview.refreshThreads",
        "title": "Refresh Threads",
        "category": "Markdown PR Review",
        "icon": "$(refresh)"
      },
      {
        "command": "markdownPrReview.addComment",
        "title": "Add Comment to Selection",
        "category": "Markdown PR Review"
      },
      {
        "command": "markdownPrReview.refreshToHead",
        "title": "Refresh to Head Commit",
        "category": "Markdown PR Review"
      },
      {
        "command": "markdownPrReview.closeSession",
        "title": "Close Session",
        "category": "Markdown PR Review"
      }
    ],
    "keybindings": [
      {
        "command": "markdownPrReview.addComment",
        "key": "ctrl+alt+c",
        "mac": "cmd+alt+c",
        "when": "activeCustomEditorId == 'markdownPrReview.renderedView'"
      },
      {
        "command": "markdownPrReview.refreshThreads",
        "key": "ctrl+alt+r",
        "mac": "cmd+alt+r",
        "when": "activeCustomEditorId == 'markdownPrReview.renderedView'"
      },
      {
        "command": "markdownPrReview.refreshToHead",
        "key": "f5",
        "when": "activeCustomEditorId == 'markdownPrReview.renderedView'"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "markdownPrReview",
          "title": "Markdown PR Review",
          "icon": "media/activity-bar.svg"
        }
      ]
    },
    "views": {
      "markdownPrReview": [
        {
          "id": "markdownPrReview.fileTree",
          "name": "Changed Files",
          "icon": "$(files)"
        },
        {
          "id": "markdownPrReview.commentInput",
          "name": "Comment Input",
          "type": "webview",
          "icon": "$(comment)"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "markdownPrReview.refreshThreads",
          "when": "view == markdownPrReview.fileTree",
          "group": "navigation"
        },
        {
          "command": "markdownPrReview.openPullRequest",
          "when": "view == markdownPrReview.fileTree",
          "group": "navigation"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "markdownPrReview.renderedView",
        "displayName": "Markdown PR Review",
        "selector": [
          {
            "filenamePattern": "*.md"
          },
          {
            "filenamePattern": "*.markdown"
          },
          {
            "filenamePattern": "*.mdx"
          }
        ],
        "priority": "option"
      }
    ],
    "configuration": {
      "title": "Markdown PR Review",
      "properties": {
        "markdownPrReview.defaultOrganization": {
          "type": "string",
          "default": "",
          "markdownDescription": "Default Azure DevOps organization. When set together with `#markdownPrReview.defaultProject#`, the **Open Pull Request** command will accept a bare PR number (e.g., `12345`) in addition to full URLs.\n\nExample: `contoso` (from `https://dev.azure.com/contoso/...`)."
        },
        "markdownPrReview.defaultProject": {
          "type": "string",
          "default": "",
          "markdownDescription": "Default Azure DevOps project. Must be set together with `#markdownPrReview.defaultOrganization#` for bare-PR-id input to work.\n\nExample: `MyProject`."
        },
        "markdownPrReview.staleCommitPollSeconds": {
          "type": "number",
          "default": 30,
          "minimum": 15,
          "maximum": 60,
          "markdownDescription": "How often (in seconds) to check whether a newer head commit has been pushed to the active PR. Range 15–60. When a newer commit is detected, a banner appears in the rendered view offering to refresh."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc --noEmit && node esbuild.js",
    "watch": "node esbuild.js --watch",
    "build": "tsc --noEmit && node esbuild.js --production",
    "lint": "eslint .",
    "package": "npm run build && vsce package --no-yarn",
    "test": "mocha"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/chai": "^4.3.20",
    "@types/diff": "^7.0.2",
    "@types/markdown-it": "^14.1.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.85.0",
    "@vscode/codicons": "^0.0.45",
    "@vscode/vsce": "^2.32.0",
    "chai": "^4.5.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.0.0",
    "mocha": "^11.7.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0"
  },
  "dependencies": {
    "diff": "^5.2.0",
    "dompurify": "^3.4.8",
    "markdown-it": "^14.1.0",
    "mermaid": "^10.9.1"
  },
  "overrides": {
    "mocha": {
      "diff": "^8.0.3",
      "serialize-javascript": "^7.0.5"
    }
  }
}
