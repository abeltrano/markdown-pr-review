# EditorConfig — keep formatting consistent across editors.
# https://editorconfig.org/
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.{json,jsonc,yml,yaml}]
indent_size = 2

[*.{css,html,htm,svg}]
indent_size = 2

[*.md]
# Two trailing spaces in markdown denote a hard line break.
trim_trailing_whitespace = false
