# Source not shipped in the .vsix
src/**
test/**
docs/**
node_modules/**
.vscode/**
.vscode-test/**
.git/**
.gitignore
esbuild.js
tsconfig.json
*.tsbuildinfo
# Source maps roughly double the package size and ship the original
# TypeScript. Use ** so nested out/**/*.map files match too.
**/*.map
.eslintrc*
.editorconfig

# Mocha test config — not loaded at runtime.
.mocharc.cjs

# Marketplace icon regeneration source. The PNG is the wired asset;
# the SVG lives in source control for regeneration but doesn't ship.
media/marketplace.svg
